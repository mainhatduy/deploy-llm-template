# API Server Configuration
HOST=0.0.0.0
PORT=8000
PROJECT_NAME="FastAPI LLM Deployment template"

# vLLM Configuration
MODEL_NAME_TYPE1=Qwen/Qwen3-0.6B
MODEL_NAME_TYPE2=Qwen/Qwen3-0.6B
GPU_MEMORY_UTILIZATION=0.4
MAX_MODEL_LEN=4096

# Optional type-specific overrides:
# GPU_MEMORY_UTILIZATION_TYPE1=0.4
# MAX_MODEL_LEN_TYPE1=4096
# GPU_MEMORY_UTILIZATION_TYPE2=0.4
# MAX_MODEL_LEN_TYPE2=4096

# Port mapping for instances
VLLM_PORT_TYPE1=8001
VLLM_PORT_TYPE2=8002

# Startup Configurations
START_VLLM_ON_STARTUP=true
VLLM_STARTUP_TIMEOUT_SECONDS=300

# Hugging Face token (optional, uncomment and set if using gated models)
# HF_TOKEN=your_token_here
